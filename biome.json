{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"root": true,
	"files": {
		"includes": ["**/*.js", "**/*.css", "**/*.json"],
		"ignoreUnknown": true
	},
	"linter": {
		"rules": {
			"complexity": {
				"noImportantStyles": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}
