{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dublin-painter/before-after-slider",
	"title": "Before / After Slider",
	"description": "Interactive image comparison slider — drag to reveal before/after.",
	"category": "dublin-painter",
	"icon": "leftright",
	"keywords": ["before", "after", "compare", "slider", "painting"],
	"attributes": {
		"beforeImage": {
			"type": "string",
			"default": "/wp-content/themes/dublin-painter/assets/images/before.jpg"
		},
		"afterImage": {
			"type": "string",
			"default": "/wp-content/themes/dublin-painter/assets/images/after.jpg"
		},
		"beforeAlt": {
			"type": "string",
			"default": "Before painting"
		},
		"afterAlt": {
			"type": "string",
			"default": "After painting"
		},
		"initialPosition": {
			"type": "number",
			"default": 50
		},
		"aspectRatio": {
			"type": "string",
			"default": "21/9"
		},
		"borderRadius": {
			"type": "string",
			"default": "24px"
		}
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./editor.js",
	"script": "file:./frontend.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css",
	"render": "file:./render.php",
	"textdomain": "dublin-painter"
}