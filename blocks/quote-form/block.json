{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dp/quote-form",
	"title": "Quote Request Form",
	"description": "Contact form with validation for quote requests.",
	"category": "dublin-painter",
	"icon": "clipboard-list",
	"version": "1.0.0",
	"textdomain": "dublin-painter",
	"attributes": {
		"heading": { "type": "string", "default": "Get Your Free Estimate" },
		"subheading": {
			"type": "string",
			"default": "Takes 60 seconds. No obligation."
		}
	},
	"supports": { "html": false, "align": ["wide", "full"] },
	"style": "file:./style.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}
