{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dp/cta-section",
	"title": "CTA Section",
	"description": "Dark call-to-action section with buttons and decorative blobs.",
	"category": "dublin-painter",
	"icon": "megaphone",
	"version": "1.0.0",
	"textdomain": "dublin-painter",
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Ready to Transform Your Space?"
		},
		"subheading": {
			"type": "string",
			"default": "Get your free, no-obligation quote today and join 500+ happy Dublin homeowners."
		},
		"ctaText": { "type": "string", "default": "Get a Free Quote" },
		"ctaUrl": { "type": "string", "default": "/get-quote" },
		"phoneText": { "type": "string", "default": "Call 01 234 5678" },
		"phoneUrl": { "type": "string", "default": "tel:+35312345678" }
	},
	"supports": { "html": false, "align": ["wide", "full"] },
	"style": "file:./style.css",
	"render": "file:./render.php"
}
